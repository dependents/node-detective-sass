{
  "name": "detective-sass",
  "version": "7.0.1",
  "description": "Find the dependencies of a sass file",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test -i fixtures",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependents/node-detective-sass.git"
  },
  "keywords": [
    "detective",
    "sass",
    "ast",
    "dependencies"
  ],
  "author": "Joel Kemp <joel@mrjoelkemp.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dependents/node-detective-sass/issues"
  },
  "homepage": "https://github.com/dependents/node-detective-sass",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "gonzales-pe": "^4.3.0",
    "node-source-walk": "^8.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  }
}
